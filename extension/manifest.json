{
  "manifest_version": 3,
  "name": "prompt-library inserter",
  "version": "0.1.0",
  "description": "Insert saved prompts and markdown snippets into any LLM textbox. Trigger with // or Ctrl+Shift+P.",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_title": "prompt-library",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "commands": {
    "open-picker": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Open the prompt picker in the focused text field"
    }
  }
}
